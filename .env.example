NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb://localhost:27017/open-source-api-boilerplate
JWT_ACCESS_SECRET=your-access-token-secret-min-32-chars-long
JWT_REFRESH_SECRET=your-refresh-token-secret-min-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
CLIENT_URL=http://localhost:3000
APP_URL=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
LOG_LEVEL=info

# Enterprise / observability
METRICS_ENABLED=true
METRICS_PATH=/metrics
METRICS_TOKEN=
AUDIT_LOG_ENABLED=true
ACCOUNT_LOCKOUT_ENABLED=true
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_DURATION_MS=900000
