{
  "name": "open-source-api-boilerplate",
  "version": "1.0.0",
  "description": "Production-ready Open Source API Boilerplate with Node.js, Express, MongoDB, and JWT Authentication",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --forceExit",
    "test:watch": "npm run test -- --watch",
    "test:coverage": "npm run test -- --coverage",
    "lint": "eslint src tests --ext .js",
    "lint:fix": "eslint src tests --ext .js --fix"
  },
  "keywords": [
    "nodejs",
    "express",
    "mongodb",
    "mongoose",
    "jwt",
    "boilerplate",
    "rest-api"
  ],
  "author": "Open Source Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/raman-kumar-sharma/open-source-api-boilerplate.git"
  },
  "bugs": {
    "url": "https://github.com/raman-kumar-sharma/open-source-api-boilerplate/issues"
  },
  "homepage": "https://github.com/raman-kumar-sharma/open-source-api-boilerplate#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.6.0",
    "prom-client": "^15.1.3",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.14.2",
    "xss-clean": "^0.1.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "eslint": "^9.9.1",
    "globals": "^15.9.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.0.0",
    "supertest": "^7.0.0"
  }
}
